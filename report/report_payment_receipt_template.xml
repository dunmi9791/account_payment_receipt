<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!--
        QWeb template for the Payment Receipt report.

        Variables available from _get_report_values:
            docs          – recordset of account.payment
            report_data   – dict keyed by payment id with:
                              balance_before   (float)
                              balance_after    (float)
                              reconciled_docs  (list of dicts)
    -->

    <!--
        Optimised for 80 mm thermal-receipt paper, portrait orientation.
        All sections use a single-column flow; font sizes are kept small
        so the content fits the ~74 mm printable width (80 mm – 3 mm margins).
    -->
    <template id="report_payment_receipt_document">
        <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang)"/>
        <t t-set="data" t-value="report_data[o.id]"/>

        <t t-call="web.external_layout">
            <div class="page" style="font-size: 10px; font-family: monospace; width: 100%;">

                <!-- ══════════════════════════════
                     TITLE
                ══════════════════════════════ -->
                <div style="text-align: center; border-bottom: 1px solid #333;
                            padding-bottom: 4px; margin-bottom: 6px;">
                    <strong style="font-size: 12px; letter-spacing: 1px; text-transform: uppercase;">
                        Payment Receipt
                    </strong>
                </div>

                <!-- ══════════════════════════════
                     PAYMENT DETAILS
                ══════════════════════════════ -->
                <table style="width: 100%; border-collapse: collapse; margin-bottom: 6px;">
                    <tbody>
                        <tr>
                            <td style="width: 42%; font-weight: bold; padding: 1px 0;">Receipt No.</td>
                            <td style="padding: 1px 0;"><span t-field="o.name"/></td>
                        </tr>
                        <tr>
                            <td style="font-weight: bold; padding: 1px 0;">Date</td>
                            <td style="padding: 1px 0;"><span t-field="o.date"/></td>
                        </tr>
                        <tr>
                            <td style="font-weight: bold; padding: 1px 0;">Journal</td>
                            <td style="padding: 1px 0;"><span t-field="o.journal_id.name"/></td>
                        </tr>
                        <tr t-if="o.payment_method_line_id">
                            <td style="font-weight: bold; padding: 1px 0;">Method</td>
                            <td style="padding: 1px 0;"><span t-field="o.payment_method_line_id.name"/></td>
                        </tr>
                        <tr t-if="o.ref">
                            <td style="font-weight: bold; padding: 1px 0;">Memo</td>
                            <td style="padding: 1px 0;"><span t-field="o.ref"/></td>
                        </tr>
                    </tbody>
                </table>

                <!-- ══════════════════════════════
                     PARTNER
                ══════════════════════════════ -->
                <div style="border-top: 1px dashed #aaa; padding-top: 4px; margin-bottom: 6px;">
                    <span style="font-weight: bold;">
                        <t t-if="o.payment_type == 'inbound'">Received from:</t>
                        <t t-else="">Paid to:</t>
                    </span>
                    <div style="margin-top: 2px;">
                        <strong t-field="o.partner_id.name"/>
                        <t t-if="o.partner_id.street">
                            <br/><span t-field="o.partner_id.street"/>
                        </t>
                        <t t-if="o.partner_id.street2">
                            <br/><span t-field="o.partner_id.street2"/>
                        </t>
                        <t t-if="o.partner_id.city or o.partner_id.zip">
                            <br/><span t-field="o.partner_id.zip"/>&#160;<span t-field="o.partner_id.city"/>
                        </t>
                        <t t-if="o.partner_id.state_id">
                            <br/><span t-field="o.partner_id.state_id.name"/>
                        </t>
                        <t t-if="o.partner_id.country_id">
                            <br/><span t-field="o.partner_id.country_id.name"/>
                        </t>
                        <t t-if="o.partner_id.vat">
                            <br/>VAT: <span t-field="o.partner_id.vat"/>
                        </t>
                    </div>
                </div>

                <!-- ══════════════════════════════
                     BALANCE SUMMARY  (stacked rows)
                ══════════════════════════════ -->
                <div style="border: 1px solid #333; padding: 4px; margin-bottom: 6px;
                            background-color: #f5f5f5;">
                    <!-- Balance before -->
                    <table style="width: 100%; border-collapse: collapse; margin-bottom: 3px;">
                        <tr>
                            <td style="font-weight: bold;">Balance Before</td>
                            <td style="text-align: right;">
                                <t t-if="data['balance_before'] &gt; 0">
                                    <span t-esc="'{:,.2f}'.format(data['balance_before'])"/>
                                    &#160;<span t-field="o.currency_id.name"/>
                                </t>
                                <t t-else="">
                                    <span style="color: green;">None</span>
                                </t>
                            </td>
                        </tr>
                    </table>
                    <!-- Amount paid – highlighted -->
                    <table style="width: 100%; border-collapse: collapse;
                                  border-top: 1px solid #333; border-bottom: 1px solid #333;
                                  margin-bottom: 3px; padding: 2px 0;">
                        <tr>
                            <td style="font-weight: bold; font-size: 11px;">Amount Paid</td>
                            <td style="text-align: right; font-weight: bold;
                                       font-size: 13px; color: #1a6bab;">
                                <span t-field="o.amount"
                                      t-options='{"widget": "monetary",
                                                  "display_currency": o.currency_id}'/>
                            </td>
                        </tr>
                    </table>
                    <!-- Balance after -->
                    <table style="width: 100%; border-collapse: collapse;">
                        <tr>
                            <td style="font-weight: bold;">Balance After</td>
                            <td style="text-align: right;">
                                <t t-if="data['balance_after'] &gt; 0">
                                    <span t-esc="'{:,.2f}'.format(data['balance_after'])"/>
                                    &#160;<span t-field="o.currency_id.name"/>
                                </t>
                                <t t-else="">
                                    <span style="color: green; font-weight: bold;">Cleared</span>
                                </t>
                            </td>
                        </tr>
                    </table>
                </div>

                <!-- ══════════════════════════════
                     RECONCILED INVOICES / BILLS
                     (3-column compact layout)
                ══════════════════════════════ -->
                <t t-if="data['reconciled_docs']">
                    <div style="border-top: 1px dashed #aaa; padding-top: 4px; margin-bottom: 6px;">
                        <div style="font-weight: bold; margin-bottom: 3px;">
                            <t t-if="o.payment_type == 'inbound'">Invoices Settled</t>
                            <t t-else="">Bills Settled</t>
                        </div>
                        <table style="width: 100%; border-collapse: collapse; font-size: 9px;">
                            <thead>
                                <tr style="border-bottom: 1px solid #333;">
                                    <th style="text-align: left; padding: 1px 0;">Doc / Date</th>
                                    <th style="text-align: right; padding: 1px 2px;">Applied</th>
                                    <th style="text-align: right; padding: 1px 0;">Remaining</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="data['reconciled_docs']" t-as="rdoc">
                                    <tr style="border-bottom: 1px dotted #ccc;">
                                        <td style="padding: 1px 0;">
                                            <span t-esc="rdoc['name']"/>
                                            <br/><span style="color:#777;" t-esc="rdoc['date']"/>
                                        </td>
                                        <td style="text-align: right; padding: 1px 2px;
                                                   color: #1a6bab; font-weight: bold;">
                                            <span t-esc="'{:,.2f}'.format(rdoc['amount_applied'])"/>
                                        </td>
                                        <td style="text-align: right; padding: 1px 0;">
                                            <t t-if="rdoc['amount_residual'] &gt; 0">
                                                <span t-esc="'{:,.2f}'.format(rdoc['amount_residual'])"/>
                                            </t>
                                            <t t-else="">
                                                <span style="color: green;">Full</span>
                                            </t>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr style="font-weight: bold; border-top: 1px solid #333;">
                                    <td style="padding: 1px 0;">Total Applied</td>
                                    <td style="text-align: right; padding: 1px 2px; color: #1a6bab;">
                                        <span t-esc="'{:,.2f}'.format(
                                            sum(r['amount_applied'] for r in data['reconciled_docs'])
                                        )"/>
                                    </td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </t>

                <!-- ══════════════════════════════
                     NOTE / MEMO
                ══════════════════════════════ -->
                <t t-if="o.move_id and o.move_id.narration">
                    <div style="border-top: 1px dashed #aaa; padding-top: 4px; margin-bottom: 6px;">
                        <div style="font-weight: bold; margin-bottom: 2px;">Note</div>
                        <p style="margin: 0;" t-field="o.move_id.narration"/>
                    </div>
                </t>

                <!-- ══════════════════════════════
                     SIGNATURE LINE
                ══════════════════════════════ -->
                <div style="border-top: 1px solid #333; margin-top: 16px; padding-top: 3px;
                            text-align: center; font-size: 9px;">
                    Authorized Signature
                </div>

            </div><!-- /page -->
        </t><!-- /web.external_layout -->

    </template>

    <!-- ══════════════════════════════════════════════════════════════
         MAIN WRAPPER – iterates over docs and sets language per partner
    ══════════════════════════════════════════════════════════════════ -->
    <template id="report_payment_receipt">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="account_payment_receipt.report_payment_receipt_document"
                   t-lang="o.partner_id.lang"/>
            </t>
        </t>
    </template>

</odoo>
