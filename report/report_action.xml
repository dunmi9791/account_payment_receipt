<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!--
        Report action for the Payment Receipt.

        - model            : account.payment  (the record being printed)
        - report_name      : account_payment_receipt.report_payment_receipt
                             → must match the <template id="..."> in the template file
        - report_type      : qweb-pdf  (renders with wkhtmltopdf)
        - binding_model_id : binds to account.payment so the report appears
                             in the ⚙ Print menu on each payment form/list view
    -->

    <record id="action_report_payment_receipt" model="ir.actions.report">
        <field name="name">Payment Receipt (balance)</field>
        <field name="model">account.payment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">account_payment_receipt.report_payment_receipt</field>
        <field name="print_report_name">
            'Payment Receipt - %s' % (object.name or object.ref or 'Draft')
        </field>
        <!-- Show in the Print menu on account.payment -->
        <field name="binding_model_id" ref="account.model_account_payment"/>
        <field name="binding_type">report</field>
        <!-- Optional: restrict to internal users only -->
        <!-- <field name="groups_id" eval="[(4, ref('account.group_account_user'))]"/> -->
    </record>

</odoo>
